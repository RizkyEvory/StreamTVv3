<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <!-- 1. Player View -->
    <androidx.media3.ui.PlayerView
        android:id="@+id/player_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:use_controller="true"
        app:show_timeout="3000"
        app:hide_on_touch="true"
        app:surface_type="surface_view"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Active Channel Banner (Overlay top left) -->
    <LinearLayout
        android:id="@+id/active_channel_overlay"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@drawable/bg_active_channel_banner"
        android:paddingHorizontal="16dp"
        android:paddingVertical="10dp"
        android:gravity="center_vertical"
        android:layout_margin="24dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="32dp"
            android:layout_height="32dp"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="@color/white"
            app:strokeWidth="1dp"
            app:strokeColor="@color/primary_cyan"
            app:cardElevation="4dp">

            <ImageView
                android:id="@+id/active_channel_logo"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="3dp"
                android:scaleType="centerInside"
                android:src="@mipmap/ic_launcher_round"
                android:contentDescription="Channel Logo" />
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <TextView
                android:id="@+id/active_channel_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Memuat Channel..."
                android:textColor="@color/text_white"
                android:textSize="14sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="2dp">

                <ImageView
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:src="@drawable/ic_live_dot"
                    android:layout_marginEnd="6dp"
                    android:contentDescription="Live indicator" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="LIVE | Streaming Tanpa Batas"
                    android:textColor="@color/primary_cyan"
                    android:textSize="10sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- Center Buffering / Loading Container -->
    <LinearLayout
        android:id="@+id/loading_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:background="#CC0A0A1A"
        android:padding="24dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ProgressBar
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:indeterminateTint="@color/primary_cyan"
            style="?android:attr/progressBarStyle" />

        <TextView
            android:id="@+id/loading_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/buffering"
            android:textColor="@color/text_white"
            android:textSize="14sp"
            android:layout_marginTop="12dp"
            android:fontFamily="sans-serif-medium" />
    </LinearLayout>

    <!-- Error View Overlay -->
    <LinearLayout
        android:id="@+id/error_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:background="#E60A0A1A"
        android:padding="32dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/error_message"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/error_failed_to_play"
            android:textColor="@color/error_red"
            android:textSize="16sp"
            android:textStyle="bold"
            android:gravity="center" />

        <Button
            android:id="@+id/btn_retry"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/btn_retry"
            android:layout_marginTop="16dp"
            android:backgroundTint="@color/highlight_purple"
            android:textColor="@color/text_white" />
    </LinearLayout>

    <!-- Slide-in Left Side Panel -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/side_panel"
        android:layout_width="@dimen/panel_width"
        android:layout_height="match_parent"
        android:background="@color/card_bg"
        android:elevation="16dp"
        android:translationX="-320dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Panel Header / Search Box -->
        <EditText
            android:id="@+id/search_bar"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_margin="12dp"
            android:hint="@string/search_hint"
            android:textColorHint="@color/text_secondary"
            android:textColor="@color/text_white"
            android:background="@drawable/bg_search_input"
            android:paddingHorizontal="16dp"
            android:textSize="14sp"
            android:inputType="text"
            android:imeOptions="actionDone"
            android:focusable="true"
            android:focusableInTouchMode="true"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Category Horizontal List -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_categories"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:orientation="horizontal"
            android:layout_marginTop="8dp"
            android:paddingHorizontal="8dp"
            android:clipToPadding="false"
            android:focusable="true"
            app:layout_constraintTop_toBottomOf="@id/search_bar" />

        <!-- Channels RecyclerView -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_channels"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"
            android:focusable="true"
            android:clipToPadding="false"
            app:layout_constraintTop_toBottomOf="@id/rv_categories"
            app:layout_constraintBottom_toTopOf="@id/panel_footer" />

        <!-- Empty state warning -->
        <TextView
            android:id="@+id/tv_empty_state"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/no_results"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/rv_categories"
            app:layout_constraintBottom_toTopOf="@id/panel_footer"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Sleek Footer with Navigation Hints and Pro Label -->
        <LinearLayout
            android:id="@+id/panel_footer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/bg_dark"
            android:padding="12dp"
            app:layout_constraintBottom_toBottomOf="parent">

            <View
                android:layout_width="match_parent"
                android:layout_height="1.5dp"
                android:background="@color/border_color"
                android:layout_marginBottom="12dp" />

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <!-- TV D-Pad Hints -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_alignParentStart="true">

                    <!-- OK Key Hint -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="OK"
                        android:textColor="@color/text_white"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:background="@drawable/bg_tv_key"
                        android:paddingHorizontal="6dp"
                        android:paddingVertical="3dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Play"
                        android:textColor="@color/text_secondary"
                        android:textSize="10sp"
                        android:layout_marginStart="4dp"
                        android:layout_marginEnd="12dp" />

                    <!-- Left/Right Key Hint -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="← / →"
                        android:textColor="@color/text_white"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:background="@drawable/bg_tv_key"
                        android:paddingHorizontal="6dp"
                        android:paddingVertical="3dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Panel"
                        android:textColor="@color/text_secondary"
                        android:textSize="10sp"
                        android:layout_marginStart="4dp" />

                </LinearLayout>

                <!-- PRO Brand Label -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="v1.0.0-PRO"
                    android:textColor="@color/highlight_purple"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.05"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true" />

            </RelativeLayout>

        </LinearLayout>
        
    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
